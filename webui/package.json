{
  "name": "pedalboard-webui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Svelte web control surface for the pi-Stomp pedalboard. Built by Vite into ../web, which the C++ server mounts at / and deploy.sh rsyncs to the Pi.",
  "scripts": {
    "dev": "vite",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build": "svelte-check --tsconfig ./tsconfig.json --threshold error && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
